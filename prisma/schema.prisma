generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspaces    Workspace[]
  subscriptions Subscription[]

  @@map("organizations")
}

model Workspace {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  slug           String
  settings       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      Member[]
  crmEntities  CrmEntity[]
  crmRecords   CrmRecord[]
  websites     Website[]
  automations  Automation[]
  aiBots       AiBot[]
  aiAgents     AiAgent[]
  packages     SmartPackage[]

  @@unique([organizationId, slug])
  @@map("workspaces")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  avatar        String?
  passwordHash  String    @map("password_hash")
  emailVerified Boolean   @default(false) @map("email_verified")
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  members   Member[]
  auditLogs AuditLog[]

  @@map("users")
}

model Member {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("member")
  permissions Json     @default("[]")
  joinedAt    DateTime @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("members")
}

model Subscription {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  plan            String    @default("free")
  status          String    @default("active")
  stripeId        String?   @map("stripe_id")
  currentPeriodEnd DateTime? @map("current_period_end")
  createdAt       DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model CrmEntity {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  displayName String   @map("display_name")
  icon        String   @default("database")
  color       String   @default("#6366f1")
  fields      Json     @default("[]")
  settings    Json     @default("{}")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  records   CrmRecord[]

  @@unique([workspaceId, name])
  @@map("crm_entities")
}

model CrmRecord {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  entityId    String    @map("entity_id")
  data        Json      @default("{}")
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entity    CrmEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([workspaceId, entityId])
  @@map("crm_records")
}

model Website {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  slug        String
  templateId  String?  @map("template_id")
  domain      String?
  published   Boolean  @default(false)
  config      Json     @default("{}")
  pages       Json     @default("[]")
  styles      Json     @default("{}")
  seo         Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("websites")
}

model Automation {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  name        String
  description String?
  trigger     Json      @default("{}")
  nodes       Json      @default("[]")
  connections Json      @default("[]")
  active      Boolean   @default(false)
  executions  Int       @default(0)
  lastRunAt   DateTime? @map("last_run_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("automations")
}

model AiBot {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  type        String   @default("custom")
  description String?
  personality Json     @default("{}")
  channels    Json     @default("[]")
  flows       Json     @default("[]")
  config      Json     @default("{}")
  active      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("ai_bots")
}

model AiAgent {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  name         String
  role         String
  description  String?
  systemPrompt String?  @map("system_prompt")
  personality  Json     @default("{}")
  tools        Json     @default("[]")
  capabilities Json     @default("[]")
  memory       Json     @default("{}")
  config       Json     @default("{}")
  active       Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("ai_agents")
}

model MarketplaceItem {
  id              String    @id @default(cuid())
  publisherId     String    @map("publisher_id")
  type            String
  name            String
  slug            String    @unique
  description     String?
  longDescription String?   @map("long_description")
  thumbnail       String?
  screenshots     Json      @default("[]")
  category        String?
  tags            Json      @default("[]")
  priceModel      String    @default("free") @map("price_model")
  priceAmount     Float?    @map("price_amount")
  currency        String    @default("USD")
  version         String    @default("1.0.0")
  blueprint       Json      @default("{}")
  ratingAvg       Float     @default(0) @map("rating_avg")
  ratingCount     Int       @default(0) @map("rating_count")
  installCount    Int       @default(0) @map("install_count")
  status          String    @default("draft")
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  reviews MarketplaceReview[]

  @@index([category, status])
  @@map("marketplace_items")
}

model MarketplaceReview {
  id        String   @id @default(cuid())
  itemId    String   @map("item_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  item MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("marketplace_reviews")
}

model SmartPackage {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  description String?
  items       Json     @default("[]")
  totalPrice  Float    @default(0) @map("total_price")
  visibility  String   @default("private")
  tags        Json     @default("[]")
  version     String   @default("1.0.0")
  usageCount  Int      @default(0) @map("usage_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("smart_packages")
}

model AuditLog {
  id           String   @id @default(cuid())
  workspaceId  String?  @map("workspace_id")
  userId       String   @map("user_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  changes      Json     @default("{}")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}
